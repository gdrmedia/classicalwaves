{
  "name": "cw.dev",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types --disable-transpile",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap --disable-transpile",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate --disable-transpile",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create --disable-transpile",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx --require ./src/scripts/patch-next-env.cjs src/scripts/seed.ts",
    "test": "cross-env NODE_OPTIONS=--no-deprecation vitest run",
    "test:watch": "cross-env NODE_OPTIONS=--no-deprecation vitest"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/plugin-seo": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/storage-vercel-blob": "^3.84.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "next": "16.2.4",
    "payload": "^3.84.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
